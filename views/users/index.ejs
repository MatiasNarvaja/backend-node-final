<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Usuarios</title>
  <link rel="stylesheet" href="/stylesheets/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Lista de Usuarios</h1>
    <a href="/users/new" class="btn btn-primary">Nuevo Usuario</a>
  </div>
  <ul class="list-group">
    <% users.forEach(user => { %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <span>
          <strong>#<%= user.id %></strong> — <%= user.email %>
          <% if (showRoles && user.role_name) { %>
            <span class="badge bg-secondary ms-2"><%= user.role_name %></span>
          <% } %>
        </span>
        <div>
          <% if (sessionUser) { %>
            <% if (sessionUser.role_id && sessionUser.role_id == user.role_id && sessionUser.id === user.id) { %>
              <a href="/users/<%= user.id %>/edit" class="btn btn-sm btn-warning me-2">Editar</a>
            <% } else if (sessionUser.role_id) { %>
              <% /* Verificamos si es ADMIN para mostrar editar y eliminar */ %>
              <% if (roles && roles.find(r => r.id == sessionUser.role_id && r.name === 'ADMIN')) { %>
                <a href="/users/<%= user.id %>/edit" class="btn btn-sm btn-warning me-2">Editar</a>
                <form action="/users/<%= user.id %>/delete" method="POST" style="display:inline;">
                  <button type="submit" class="btn btn-sm btn-danger">Eliminar</button>
                </form>
              <% } %>
            <% } %>
          <% } %>
        </div>
      </li>
    <% }) %>
  </ul>
</body>
</html>
